{
  "version": 2,
  "functions": {
    "api/**/*.js": { "maxDuration": 60 }
  },
  "routes": [
    { "src": "/v1/(.*)", "dest": "/api/v1/$1" },
    { "src": "/api/(.*)", "dest": "/api/$1" },
    { "src": "/", "dest": "/public/index.html" },
    { "src": "/admin", "dest": "/public/admin.html" },
    { "src": "/docs", "dest": "/public/docs.html" }
  ]
}

